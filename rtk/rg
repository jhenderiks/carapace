#!/bin/sh
# rg → rtk grep wrapper with flag translation
# Same issue as grep wrapper: rtk grep expects PATTERN first, rg allows flags first.
# See grep wrapper for full documentation.
#
# Upstream: rtk-ai/rtk#229, #236.

if [ -n "$_RTK_WRAP" ]; then
  PATH="${PATH#/opt/rtk:}"; export PATH; exec rg "$@"
fi
if [ $# -eq 0 ]; then
  PATH="${PATH#/opt/rtk:}"; export PATH; exec rg
fi

# No leading flags → straight to rtk
case "$1" in
  -*) ;;
  *) export _RTK_WRAP=1; exec rtk grep "$@" ;;
esac

# Check for flags that must fall back
for _a in "$@"; do
  case "$_a" in
    -c|--count|-l|--files-with-matches|-e|--regexp) PATH="${PATH#/opt/rtk:}"; export PATH; exec rg "$@" ;;
    -[!-]*c*|-[!-]*l*) PATH="${PATH#/opt/rtk:}"; export PATH; exec rg "$@" ;;
  esac
done

# Separate leading flags from positional args
_flags=""
_pattern=""
_path=""

for _a in "$@"; do
  if [ -z "$_pattern" ]; then
    case "$_a" in
      -A|-B|-C|-m|--after-context|--before-context|--context|--max-count)
        _flags="${_flags:+$_flags }_VALFLAG_${_a}" ;;
      -[ABC][0-9]*)
        _flags="${_flags:+$_flags }${_a}" ;;
      # Translate conflicting short flags to long rg equivalents
      -v) _flags="${_flags:+$_flags }--invert-match" ;;
      -o) _flags="${_flags:+$_flags }--only-matching" ;;
      -*)
        _flags="${_flags:+$_flags }${_a}" ;;
      *)
        case "$_flags" in
          *_VALFLAG_*)
            _vf="${_flags##*_VALFLAG_}"
            _vf="${_vf%% *}"
            _flags="${_flags%_VALFLAG_*}${_vf} ${_a}"
            ;;
          *)
            _pattern="$_a" ;;
        esac ;;
    esac
  elif [ -z "$_path" ]; then
    case "$_a" in
      -*) _flags="${_flags:+$_flags }${_a}" ;;
      *) _path="$_a" ;;
    esac
  else
    _flags="${_flags:+$_flags }${_a}"
  fi
done

if [ -z "$_pattern" ]; then
  PATH="${PATH#/opt/rtk:}"; export PATH; exec rg "$@"
fi

export _RTK_WRAP=1
if [ -n "$_path" ]; then
  eval "exec rtk grep \"\$_pattern\" \"\$_path\" $_flags"
else
  eval "exec rtk grep \"\$_pattern\" . $_flags"
fi
