#!/bin/sh
set -eu

COMMAND=$1
shift

strip_rtk_path() {
  NEXT_PATH=""
  OLD_IFS=$IFS
  IFS=:

  for PART in ${PATH-}; do
    if [ -z "$PART" ] || [ "$PART" = "/opt/rtk" ]; then
      continue
    fi

    if [ -z "$NEXT_PATH" ]; then
      NEXT_PATH=$PART
    else
      NEXT_PATH="${NEXT_PATH}:$PART"
    fi
  done

  IFS=$OLD_IFS
  printf '%s' "$NEXT_PATH"
}

run_native() {
  PATH=$(strip_rtk_path)
  export PATH
  exec "$COMMAND" "$@"
}

run_rtk() {
  PATH=$(strip_rtk_path)
  export PATH
  export _RTK_WRAP=1
  exec rtk "$@"
}

shell_quote() {
  case "${1-}" in
    "")
      printf "''"
      ;;
    *[!A-Za-z0-9_@%+=:,./-]*)
      printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\"'\"'/g")"
      ;;
    *)  
      printf '%s' "$1"
      ;;
  esac
}

append_shell_quoted_arg() {
  _quoted_arg=$(shell_quote "$1")
  if [ -z "${_normalized_args-}" ]; then
    _normalized_args=$_quoted_arg
  else
    _normalized_args="${_normalized_args} ${_quoted_arg}"
  fi
}

env_option_consumes_next_token() {
  case "$1" in
    --chdir|--default-signal|--ignore-signal|--signal|--split-string|--unset)
      return 0
      ;;
    --*)
      return 1
      ;;
    *)
      _short_option_chars=${1#-}
      while [ -n "$_short_option_chars" ]; do
        _short_option_char=${_short_option_chars%"${_short_option_chars#?}"}
        case "$_short_option_char" in
          C|S|u)
            if [ -n "${_short_option_chars#?}" ]; then
              return 1
            fi
            return 0
            ;;
        esac
        _short_option_chars=${_short_option_chars#?}
      done
      return 1
      ;;
  esac
}

exec_normalized_env_rewrite() {
  _rtk_bin=$(command -v rtk 2>/dev/null || printf '')
  if [ -z "$_rtk_bin" ]; then
    return 1
  fi

  if ! eval "set -- $1"; then
    return 1
  fi

  if [ "${1-}" != "env" ]; then
    return 1
  fi
  shift

  _normalized_args=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --|-)
        append_shell_quoted_arg "$1"
        shift
        break
        ;;
      [A-Za-z_][A-Za-z0-9_]*=*)
        append_shell_quoted_arg "$1"
        shift
        ;;
      -*)
        _option=$1
        append_shell_quoted_arg "$_option"
        shift
        if env_option_consumes_next_token "$_option" && [ "$#" -gt 0 ]; then
          append_shell_quoted_arg "$1"
          shift
        fi
        ;;
      *)
        break
        ;;
    esac
  done

  if [ "${1-}" != "rtk" ]; then
    return 1
  fi

  append_shell_quoted_arg "$_rtk_bin"
  shift
  while [ "$#" -gt 0 ]; do
    append_shell_quoted_arg "$1"
    shift
  done

  PATH=$(strip_rtk_path)
  export PATH
  export _RTK_WRAP=1
  eval "set -- $_normalized_args"
  exec env "$@"
}

stdin_is_pipe() {
  if [ -t 0 ]; then
    return 1
  fi

  _stdin_target=$(readlink /proc/self/fd/0 2>/dev/null || printf '')
  case "$_stdin_target" in
    /dev/null|'')
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

if [ -n "${_RTK_WRAP:-}" ]; then
  run_native "$@"
fi

if [ -n "${RTK_DISABLED:-}" ] && [ "${RTK_DISABLED}" != "0" ]; then
  run_native "$@"
fi

if ! command -v rtk >/dev/null 2>&1; then
  run_native "$@"
fi

case "$COMMAND" in
  cat)
    if [ "$#" -eq 0 ]; then
      run_native "$@"
    fi
    ;;
  head)
    case "${1-}" in
      -[0-9]*)
        if [ "$#" -ge 2 ]; then
          LINES=${1#-}
          shift
          run_rtk read "$@" --max-lines "$LINES"
        fi
        ;;
      -n)
        if [ "$#" -ge 3 ]; then
          LINES=$2
          shift 2
          run_rtk read "$@" --max-lines "$LINES"
        fi
        ;;
      --lines=*)
        if [ "$#" -ge 2 ]; then
          LINES=${1#--lines=}
          shift
          run_rtk read "$@" --max-lines "$LINES"
        fi
        ;;
    esac
    ;;
  tail)
    run_native "$@"
    ;;
  grep)
    if stdin_is_pipe; then
      run_native "$@"
    fi
    case "${1-}" in
      -*)
        run_native "$@"
        ;;
    esac
    ;;
  rg)
    if stdin_is_pipe; then
      run_native "$@"
    fi
    case "${1-}" in
      -*)
        run_native "$@"
        ;;
    esac
    ;;
esac

ORIGINAL_COMMAND=$(shell_quote "$COMMAND")
for ARG in "$@"; do
  ORIGINAL_COMMAND="${ORIGINAL_COMMAND} $(shell_quote "$ARG")"
done

if ! REWRITTEN=$(rtk rewrite "$ORIGINAL_COMMAND" 2>/dev/null); then
  run_native "$@"
fi

if [ -z "$REWRITTEN" ] || [ "$REWRITTEN" = "$ORIGINAL_COMMAND" ]; then
  run_native "$@"
fi

if [ "$COMMAND" = "env" ]; then
  exec_normalized_env_rewrite "$REWRITTEN"
fi

PATH=$(strip_rtk_path)
export PATH
export _RTK_WRAP=1
exec /bin/sh -c "$REWRITTEN"
