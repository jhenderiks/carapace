#!/bin/sh
# grep → rtk grep wrapper with flag translation
# rtk grep expects: <PATTERN> [PATH] [EXTRA_ARGS...]
# native grep uses:  [-FLAGS] <PATTERN> [PATH...]
# This wrapper reorders leading flags to trail the positional args.
#
# Conflicting short flags (-v -c -l mean different things in rtk vs grep):
#   grep -v = invert match     | rtk -v = verbose  → translate to --invert-match
#   grep -c = count            | rtk -c = context-only  → fall back (output is 1 number)
#   grep -l = files-with-match | rtk -l = max-len  → fall back (rtk eats filename output)
#   grep -o = only-matching    → translate to --only-matching
# For -c, -l, -e (pattern-in-flag): fall back to native grep.
# For -v, -o: translate to long rg equivalents (rtk passes them through to rg).
#
# Upstream: rtk-ai/rtk#229, #236. Remove translation once rtk accepts
# flags before pattern in its clap parser.

if [ -n "$_RTK_WRAP" ]; then
  PATH=$(echo "$PATH" | sed "s,/opt/rtk:,,g"); export PATH; exec grep "$@"
fi
if [ $# -eq 0 ]; then
  PATH=$(echo "$PATH" | sed "s,/opt/rtk:,,g"); export PATH; exec grep
fi
# Redirected stdin → native grep (filter mode, not workspace search).
# Non-interactive agent exec commonly attaches stdin to /dev/null; that
# should still use rtk grep instead of forcing a native grep fallback.
if [ ! -t 0 ]; then
  _stdin_target=$(readlink /proc/self/fd/0 2>/dev/null || printf '')
  case "$_stdin_target" in
    /dev/null|'') ;;
    *)
      PATH="${PATH#/opt/rtk:}"; export PATH; exec grep "$@"
      ;;
  esac
fi

# No leading flags → straight to rtk
case "$1" in
  -*) ;;
  *) export _RTK_WRAP=1; exec rtk grep "$@" ;;
esac

# Check for flags that must fall back (first pass — don't consume args)
for _a in "$@"; do
  case "$_a" in
    # These produce minimal output that rtk can't compress, or are too complex
    -c|--count|-l|--files-with-matches|-e|--regexp) PATH=$(echo "$PATH" | sed "s,/opt/rtk:,,g"); export PATH; exec grep "$@" ;;
    # Combined flags containing -c or -l conflicts
    -[!-]*c*|-[!-]*l*) PATH=$(echo "$PATH" | sed "s,/opt/rtk:,,g"); export PATH; exec grep "$@" ;;
  esac
done

# Second pass: separate leading flags from positional args
# Keep flags newline-delimited so we can rebuild argv without eval.
append_flag() {
  if [ -n "$_flags_nl" ]; then
    _flags_nl="${_flags_nl}
$1"
  else
    _flags_nl="$1"
  fi
}

_flags_nl=""
_pattern=""
_path=""
_pending_flag=""

for _a in "$@"; do
  if [ -n "$_pending_flag" ]; then
    append_flag "$_pending_flag"
    append_flag "$_a"
    _pending_flag=""
    continue
  fi

  if [ -z "$_pattern" ]; then
    case "$_a" in
      # Flags that take a value: buffer next arg
      -A|-B|-C|-m|--after-context|--before-context|--context|--max-count)
        _pending_flag="$_a" ;;
      # Combined: -A5, -B3, -C2
      -[ABC][0-9]*)
        append_flag "$_a" ;;
      # Translate conflicting short flags to long rg equivalents
      -v) append_flag "--invert-match" ;;
      -o) append_flag "--only-matching" ;;
      # grep regex mode flags: rg defaults to extended, strip or translate
      -E|--extended-regexp|-G|--basic-regexp) ;; # rg handles these natively, skip
      -F|--fixed-strings) append_flag "-F" ;;
      -P|--perl-regexp) append_flag "-P" ;;
      -w|--word-regexp) append_flag "-w" ;;
      # Any other flag
      -*)
        append_flag "$_a" ;;
      *)
        _pattern="$_a" ;;
    esac
  elif [ -z "$_path" ]; then
    case "$_a" in
      -*) append_flag "$_a" ;;
      *) _path="$_a" ;;
    esac
  else
    # Additional args after pattern + path go to flags
    append_flag "$_a"
  fi
done

# If we couldn't extract a pattern, fall back
if [ -n "$_pending_flag" ] || [ -z "$_pattern" ]; then
  PATH=$(echo "$PATH" | sed "s,/opt/rtk:,,g"); export PATH; exec grep "$@"
fi

export _RTK_WRAP=1
_old_IFS="$IFS"
IFS='
'
set -f
if [ -n "$_path" ]; then
  set -- "$_pattern" "$_path"
else
  set -- "$_pattern" "."
fi
for _flag in $_flags_nl; do
  set -- "$@" "$_flag"
done
IFS="$_old_IFS"
set +f
exec rtk grep "$@"
