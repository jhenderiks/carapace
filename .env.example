# openclaw gateway
OPENCLAW_GATEWAY_TOKEN=

# channels (optional)
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# model providers (enable at least one if not using oauth)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# skills (optional)
BRAVE_API_KEY=
GITHUB_TOKEN=
NOTION_API_KEY=

# security (2026.3.2+): allow plaintext WS from private network IPs
# required if gateway is accessed from LAN (e.g. web UI on private IP)
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
