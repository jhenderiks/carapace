# dependencies
node_modules/

# separate build contexts
browser/

# env & config
.env
.env.example
.envrc

# runtime directories (volume-mounted)
config/
workspace/
.local/

# git & ci
.git/
.github/
.githooks/
.gitignore

# nix
.direnv/
flake.nix
flake.lock

# editor
.cursor/

# docs
/README.md
/LICENSE

