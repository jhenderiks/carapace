# dependencies
**/node_modules/

# local plugin build/test artifacts
plugins/*/dist/
plugins/*/coverage/
plugins/*/.turbo/
plugins/*/.cache/
plugins/*/*.tsbuildinfo

# plugin docs/tests are not needed in the runtime image
plugins/*/README.md
plugins/**/*.test.ts

# separate build contexts
browser/

# env & config
.env
.env.example
.envrc

# runtime directories (volume-mounted)
config/
workspace/
.local/

# git & ci
.git/
.github/
.githooks/
.gitignore

# nix
.direnv/
flake.nix
flake.lock

# editor
.cursor/

# docs
/README.md
/LICENSE

# docker meta (read separately by docker, not needed in build context)
docker-compose*.yml
Dockerfile*
.dockerignore

# typescript config (bun handles ts natively at runtime)
tsconfig.json

# os
.DS_Store
.fuse_hidden*
Thumbs.db
