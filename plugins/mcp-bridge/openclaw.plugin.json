{
  "id": "mcp-bridge",
  "name": "MCP Bridge",
  "description": "Bridge MCP stdio servers into OpenClaw agent tools",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "servers": {
        "type": "object",
        "description": "MCP server definitions keyed by server id",
        "additionalProperties": {
          "$ref": "#/$defs/server"
        },
        "default": {}
      },
      "rtk": {
        "type": "object",
        "additionalProperties": false,
        "description": "Reserved for Phase 2 (before_tool_call RTK routing)",
        "properties": {
          "enabled": { "type": "boolean" },
          "binary": { "type": "string" },
          "allIntercept": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skip": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "$defs": {
      "server": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "command": { "type": "string" },
          "args": {
            "type": "array",
            "items": { "type": "string" }
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "lifecycle": {
            "type": "string",
            "enum": ["gateway", "session"],
            "default": "gateway"
          },
          "toolPrefix": { "type": "string" },
          "optional": { "type": "boolean", "default": false },
          "disabled": { "type": "boolean", "default": false },
          "timeoutMs": { "type": "number", "default": 30000 },
          "retryCount": { "type": "number", "default": 1 },
          "retryBackoffMs": { "type": "number", "default": 500 }
        },
        "required": ["command"]
      }
    }
  }
}
